<?xml version="1.0" encoding="utf-8"?>
<!-- Privacy: no cloud backup of financial data. Disable cloud + device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
